# Security Settings
SECRET_KEY=replace-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=
# Leave blank for the built-in SQLite fallback, or set to PostgreSQL in Docker/prod.
DATABASE_URL=
MEDIA_ROOT=/app/media
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

POSTGRES_DB=llkmusic
POSTGRES_USER=llkmusic
POSTGRES_PASSWORD=replace-me

# Contact Form Email
# Use an app password for Gmail SMTP, not your normal account password.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_TIMEOUT=10
EMAIL_HOST_USER=your-sender@gmail.com
EMAIL_HOST_PASSWORD=replace-with-app-password
DEFAULT_FROM_EMAIL=LLKMusic <your-sender@gmail.com>
CONTACT_FORM_RECIPIENTS=kkadzi25@gmail.com
